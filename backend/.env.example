# Photo Coach -- Default Engine Config
# Copy this file to .env and fill in your API key.
# This engine is used when user does NOT provide a custom API key in the frontend settings.

# Provider: openai | anthropic
DEFAULT_PROVIDER=anthropic

# Model name (provider-specific)
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# OpenAI:   gpt-4o, gpt-4o-mini
DEFAULT_MODEL=claude-sonnet-4-20250514

# API Key (required)
# Anthropic official: sk-ant-...
# OpenAI official:    sk-...
# Custom proxy:       as provided by the proxy service
DEFAULT_API_KEY=your-api-key-here

# Base URL (optional, leave empty for official default)
# Anthropic: https://api.anthropic.com (or .../v1, both accepted)
# OpenAI:   https://api.openai.com (or .../v1, both accepted)
# Proxy:    https://your-proxy.com (or .../v1, both accepted)
# Local:    http://localhost:11434/v1
DEFAULT_BASE_URL=
